{
  "name": "wso2-integrator",
  "displayName": "WSO2 Integrator",
  "description": "Unified integration development environment for WSO2 BI and MI in VS Code",
  "version": "1.0.0",
  "cliVersion": "v1.2.212603061900",
  "publisher": "wso2",
  "icon": "resources/icons/wso2-integrator-logo.png",
  "license": "Apache-2.0",
  "repository": {
    "url": "https://github.com/wso2/vscode-extensions"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "WSO2 Integrator",
      "properties": {
        "integrator.enabledRuntimes.bi": {
          "type": "boolean",
          "default": true,
          "description": "Enable WSO2 BI runtime."
        },
        "integrator.enabledRuntimes.mi": {
          "type": "boolean",
          "default": false,
          "description": "Enable WSO2 MI runtime."
        },
        "integrator.advanced.cloudEnv": {
          "type": "string",
          "enum": [
            "prod",
            "stage",
            "dev"
          ],
          "default": "prod",
          "description": "The WSO2 Cloud Environment to use",
          "scope": "machine"
        },
        "integrator.advanced.cloudRpcPath": {
          "type": "string",
          "default": "",
          "description": "The path to Cloud RPC server",
          "scope": "window"
        },
        "integrator.advanced.cloudRpcArchitecture": {
          "type": "string",
          "enum": [
            "",
            "amd64",
            "arm64"
          ],
          "default": "",
          "description": "The architecture of Cloud RPC server. Change only if you are running within a container with a different architecture than your host machine.",
          "scope": "window"
        },
        "integrator.advanced.skipKeyring": {
          "type": "boolean",
          "default": false,
          "description": "Enable only if your system does not support keyring.",
          "scope": "window"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wso2-integrator",
          "title": "WSO2 Integrator",
          "icon": "resources/icons/integrator-icon.svg"
        }
      ]
    },
    "views": {
      "wso2-integrator": [
        {
          "id": "wso2-integrator.explorer",
          "name": "Integrations",
          "contextualTitle": "WSO2 Integrator"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "wso2-integrator.explorer",
        "contents": "$(loadingspin) Loading WSO2 Integrator...",
        "when": "WI.projectType != 'none'"
      },
      {
        "view": "wso2-integrator.explorer",
        "contents": "Welcome to WSO2 Integrator.\n[Get Started](command:wso2.integrator.openWelcome)",
        "when": "WI.projectType == 'none'"
      }
    ],
    "commands": [
      {
        "command": "wso2.integrator.openWelcome",
        "title": "Open Welcome Page",
        "category": "WSO2 Integrator",
        "icon": "$(home)"
      },
      {
        "command": "wso2-integrator.explorer.refresh",
        "title": "Refresh",
        "category": "WSO2 Integrator",
        "icon": "$(refresh)"
      },
      {
        "command": "wso2.integrator.openBIIntegration",
        "title": "Open BI Integration",
        "category": "WSO2 Integrator"
      },
      {
        "command": "wso2.integrator.openMIIntegration",
        "title": "Open MI Integration",
        "category": "WSO2 Integrator"
      },
      {
        "command": "wso2.integrator.cloud.auth.signIn",
        "title": "Sign In",
        "category": "WSO2 Integrator",
        "icon": "$(sign-in)",
        "enablement": "!isLoggedIn"
      },
      {
        "command": "wso2.integrator.cloud.auth.signOut",
        "title": "Sign Out",
        "category": "WSO2 Integrator",
        "icon": "$(sign-out)",
         "enablement": "isLoggedIn"
      },
      {
        "command": "wso2.integrator.cloud.auth.cancelSignIn",
        "title": "Cancel Sign In",
        "category": "WSO2 Integrator"
      },
      {
        "command": "wso2.integrator.cloud.integration.create",
        "title": "Deploy Integration to Cloud",
        "category": "WSO2 Integrator",
        "icon": "$(add)"
      },
      {
        "command": "wso2.integrator.cloud.integration.delete",
        "title": "Delete Integration from Cloud",
        "category": "WSO2 Integrator",
        "icon": "$(trash)"
      },
      {
        "command": "wso2.integrator.cloud.integration.openInConsole",
        "title": "Open in Cloud Console",
        "category": "WSO2 Integrator",
        "icon": "$(link-external)"
      },
      {
        "command": "wso2.integrator.cloud.project.clone",
        "title": "Clone Cloud Project Repository",
        "category": "WSO2 Integrator",
        "icon": "$(repo-clone)"
      },
      {
        "command": "wso2.integrator.cloud.project.createContext",
        "title": "Associate Cloud Project",
        "category": "WSO2 Integrator",
        "icon": "$(link)"
      },
      {
        "command": "wso2.integrator.cloud.project.manageContext",
        "title": "Manage Cloud Project",
        "category": "WSO2 Integrator",
        "icon": "$(settings-gear)"
      },
      {
        "command": "wso2.integrator.cloud.project.refresh",
        "title": "Refresh Workspace",
        "category": "WSO2 Integrator",
        "icon": "$(refresh)",
        "enablement": "!isLoadingContextDirs"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "ballerina.showVisualizer",
          "when": "view == wso2-integrator.explorer && viewItem == bi-project",
          "group": "inline"
        },
        {
          "command": "ballerina.force.update.artifacts",
          "when": "view == wso2-integrator.explorer && viewItem == bi-project",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-connection",
          "when": "view == wso2-integrator.explorer && viewItem == connections",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.delete",
          "when": "view == wso2-integrator.explorer && viewItem == CONNECTION || viewItem == SERVICE || viewItem == FUNCTION || viewItem == AUTOMATION || viewItem == TYPE || viewItem == CONFIGURABLE || viewItem == DATA_MAPPER || viewItem == NP_FUNCTION || viewItem == localConnector",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-entry-point",
          "when": "view == wso2-integrator.explorer && viewItem == entryPoint",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-type",
          "when": "view == wso2-integrator.explorer && viewItem == types",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.view-type-diagram",
          "when": "view == wso2-integrator.explorer && viewItem == types",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-function",
          "when": "view == wso2-integrator.explorer && viewItem == functions",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-configuration",
          "when": "view == wso2-integrator.explorer && viewItem == configurations",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.view-configuration",
          "when": "view == wso2-integrator.explorer && viewItem == configurations",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-data-mapper",
          "when": "view == wso2-integrator.explorer && viewItem == dataMappers",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-natural-function",
          "when": "view == wso2-integrator.explorer && viewItem == naturalFunctions",
          "group": "inline"
        },
        {
          "command": "BI.project-explorer.add-custom-connector",
          "when": "view == wso2-integrator.explorer && viewItem == localConnectors",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "wso2-integrator.explorer.refresh",
          "when": "view == wso2-integrator.explorer",
          "group": "navigation@2"
        },
        {
          "command": "BI.project-explorer.add",
          "when": "view == wso2-integrator.explorer && BI.project == true",
          "group": "navigation"
        },
        {
          "command": "BI.project-explorer.overview",
          "when": "view == wso2-integrator.explorer && BI.project == true",
          "group": "navigation"
        }
      ]
    },
    "icons": {}
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "vscode:prepublish": "rm -rf resources/jslibs && npm run copyJSLibs",
    "prebuild": "rm -rf dist",
    "build": "webpack --mode production && npm run download-choreo-cli && npm run package",
    "copyJSLibs": "copyfiles -E -f ../wi-webviews/build/main.js resources/jslibs",
    "watch": "webpack --mode development --watch",
    "compile": "webpack --mode development",
    "compile-tests": "tsc -p . --outDir out",
    "test": "node ./out/test/runTest.js",
    "package": "node ../../external/wso2-vscode-extensions/workspaces/common-libs/scripts/package-vsix.js",
    "download-choreo-cli": "node scripts/download-choreo-cli.js"
  },
  "devDependencies": {
    "@types/byline": "4.2.33",
    "@types/js-yaml": "4.0.9",
    "@types/which": "3.0.4",
    "@vscode/vsce": "3.4.0",
    "@types/vscode": "1.100.0",
    "@types/mocha": "10.0.3",
    "@types/node": "22.15.21",
    "@typescript-eslint/eslint-plugin": "8.32.1",
    "@typescript-eslint/parser": "8.32.1",
    "@vscode/test-electron": "2.5.2",
    "eslint": "9.27.0",
    "glob": "11.0.2",
    "mocha": "11.2.2",
    "typescript": "5.8.3",
    "copyfiles": "2.4.1",
    "copy-webpack-plugin": "13.0.0",
    "source-map-support": "0.5.21",
    "ts-loader": "9.5.2",
    "webpack": "5.102.1",
    "webpack-cli": "6.0.1",
    "webpack-permissions-plugin": "1.0.9",
    "@playwright/test": "1.55.1",
    "@wso2/wi-webviews": "workspace:*"
  },
  "dependencies": {
    "@wso2/wi-core": "workspace:*",
    "@wso2/wso2-platform-core": "workspace:*",
    "vscode-messenger-common": "^0.5.1",
    "vscode-messenger": "~0.5.1",
    "vscode-jsonrpc": "8.2.1",
    "zustand": "5.0.5",
    "byline": "5.0.0",
    "which": "5.0.0",
    "js-yaml": "4.1.1",
    "yaml": "2.8.0",
    "@vscode/iconv-lite-umd": "^0.7.0",
    "file-type": "^18.2.1",
    "jschardet": "^3.1.4",
    "vscode-webview-network-bridge": "1.1.1",
    "xstate": "4.38.3",
    "@emotion/styled": "11.14.1",
    "@wso2/ui-toolkit": "workspace:*",
    "unzipper": "0.12.3",
    "@types/unzipper": "0.10.11",
    "axios": "1.13.2",
    "dotenv": "17.2.3"
  }
}
