+
+function _resolveRuntimeEnvMap(
+	runtimeEnv: IProductConfiguration['runtimeEnv'],
+	platform: string
+): IProductRuntimeEnvironmentMap | undefined {
+	if (!runtimeEnv || typeof runtimeEnv !== 'object') {
+		return undefined;
+	}
+
+	const runtimeEnvRecord = runtimeEnv as Record<string, unknown>;
+	const osKeys = new Set(['darwin', 'linux', 'win32', 'common', 'default']);
+	const containsOsKeys = Object.keys(runtimeEnvRecord).some(key => osKeys.has(key));
