+	return {
+		replace,
+		pathPrepend: _deserializePathEntries(pathPrepend),
+		pathAppend: _deserializePathEntries(pathAppend),
+		pathRemovePattern
+	};
+}
+
+export function applyStoredProductRuntimeEnvironment(env: IProcessEnvironment): void {
+	applyProductRuntimeEnvironment(env, getStoredProductRuntimeEnvironment(env));
