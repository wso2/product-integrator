+function _mergeRuntimeEnvMaps(...maps: Array<IProductRuntimeEnvironmentMap | undefined>): IProductRuntimeEnvironmentMap | undefined {
+	const merged: Record<string, unknown> = {};
+	const mergedMeta: Record<string, unknown> = {};
