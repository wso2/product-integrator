+	return Object.keys(merged).length > 0 ? merged as IProductRuntimeEnvironmentMap : undefined;
+}
+
+function _asRuntimeEnvMap(value: unknown): IProductRuntimeEnvironmentMap | undefined {
+	return value && typeof value === 'object' ? value as IProductRuntimeEnvironmentMap : undefined;
