+		for (const [key, value] of Object.entries(map)) {
+			if (key === RUNTIME_ENV_META_KEY && value && typeof value === 'object') {
+				Object.assign(mergedMeta, value);
+				continue;
+			}
+			merged[key] = value;
+		}
+	}
