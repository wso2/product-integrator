+
+function _parseConfiguredPath(value: string, appRoot: string): { prepend?: string; append?: string } {
+	const resolvedValue = value.replace(APP_ROOT_TOKEN_REGEX, appRoot);
+	const pathTokenMatch = PATH_TOKEN_REGEX.exec(resolvedValue);
+	if (!pathTokenMatch) {
