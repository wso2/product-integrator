+		.split(path.delimiter)
+		.map(entry => entry.trim())
+		.filter(entry => entry.length > 0)
+		.map(entry => _resolvePathEntry(entry, appRoot));
+
+	return entries.length > 0 ? entries.join(path.delimiter) : undefined;
