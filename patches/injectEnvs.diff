+}
+
+function _getPathValue(env: IProcessEnvironment): string {
+	return env[_getPathKey(env)] || '';
+}
+
+function _isPathKey(key: string): boolean {
+	return key.toLowerCase() === 'path';
+}
+
+function _isRelativePath(value: string): boolean {
+	return value.startsWith('./') || value.startsWith('../') || value.startsWith('.\\') || value.startsWith('..\\');
