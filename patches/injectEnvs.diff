+
+function _serializePathEntries(value: string | undefined): string | undefined {
+	const serialized = _splitPathEntries(value)
+		.map(entry => _encodeColons(entry))
+		.join(':');
+	return serialized || undefined;
+}
+
+function _deserializeEnvEntries(serialized: string): IProcessEnvironment {
+	const env: IProcessEnvironment = {};
+	for (const entry of serialized.split(':')) {
+		if (entry.length === 0) {
+			continue;
+		}
+
+		const separatorIndex = entry.indexOf('=');
+		if (separatorIndex === -1) {
+			continue;
+		}
+
+		const key = entry.slice(0, separatorIndex);
+		const value = entry.slice(separatorIndex + 1);
+		env[key] = value.replaceAll('\\x3a', ':');
+	}
+	return env;
+}
+
+function _deserializePathEntries(serialized: string | undefined): string | undefined {
+	if (!serialized) {
+		return undefined;
+	}
+
+	const entries = serialized
+		.split(':')
+		.map(entry => entry.replaceAll('\\x3a', ':'))
+		.filter(entry => entry.length > 0);
+	return entries.length > 0 ? entries.join(path.delimiter) : undefined;
+}
+
+function _encodeColons(value: string): string {
+	return value.replaceAll(':', '\\x3a');
+}
+
+function _setOrDelete(env: IProcessEnvironment, key: string, value: string | undefined): void {
+	if (value) {
+		env[key] = value;
+	} else {
+		delete env[key];
+	}
+}
+
+function _getActualKey(env: IProcessEnvironment, key: string): string {
+	if (!isWindows) {
+		return key;
+	}
