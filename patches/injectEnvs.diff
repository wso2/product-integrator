+
+export function storeProductRuntimeEnvironment(
+	env: IProcessEnvironment,
+	runtimeEnv: IResolvedProductRuntimeEnvironment | undefined
+): void {
+	if (!runtimeEnv) {
+		delete env[VSCODE_PRODUCT_RUNTIME_ENV_REPLACE];
+		delete env[VSCODE_PRODUCT_RUNTIME_PATH_PREPEND];
+		delete env[VSCODE_PRODUCT_RUNTIME_PATH_APPEND];
+		delete env[VSCODE_PRODUCT_RUNTIME_PATH_REMOVE_PATTERN];
+		return;
+	}
