+
+export function getStoredProductRuntimeEnvironment(env: IProcessEnvironment): IResolvedProductRuntimeEnvironment | undefined {
+	const runtimeEnvReplace = env[VSCODE_PRODUCT_RUNTIME_ENV_REPLACE];
+	const pathPrepend = env[VSCODE_PRODUCT_RUNTIME_PATH_PREPEND];
+	const pathAppend = env[VSCODE_PRODUCT_RUNTIME_PATH_APPEND];
+	const pathRemovePattern = env[VSCODE_PRODUCT_RUNTIME_PATH_REMOVE_PATTERN];
+
+	const replace = runtimeEnvReplace ? _deserializeEnvEntries(runtimeEnvReplace) : {};
+	if (Object.keys(replace).length === 0 && !pathPrepend && !pathAppend && !pathRemovePattern) {
+		return undefined;
+	}
