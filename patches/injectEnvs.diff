+
+function _getPathRemovePattern(runtimeEnv: IProductRuntimeEnvironmentMap): string | undefined {
+	const meta = runtimeEnv[RUNTIME_ENV_META_KEY];
+	if (!meta || typeof meta !== 'object') {
+		return undefined;
+	}
+
+	const pattern = (meta as Record<string, unknown>)[PATH_REMOVE_PATTERN_KEY];
+	return typeof pattern === 'string' && pattern.length > 0 ? pattern : undefined;
+}
+
+function _parseRegex(pattern: string | undefined): RegExp | undefined {
+	if (!pattern) {
+		return undefined;
+	}
+
+	try {
+		return new RegExp(pattern);
+	} catch {
+		return undefined;
+	}
+}
+
+function _splitPathEntries(value: string | undefined): string[] {
+	return (value || '')
+		.split(path.delimiter)
+		.map(entry => entry.trim())
+		.filter(entry => entry.length > 0);
+}
+
+function _serializeEnvEntries(entries: IProcessEnvironment): string | undefined {
+	const serialized = Object.entries(entries)
+		.filter(([, value]) => typeof value === 'string')
+		.map(([key, value]) => `${key}=${_encodeColons(value!)}`)
+		.join(':');
