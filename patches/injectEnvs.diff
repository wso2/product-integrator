+	return {
+		replace,
+		pathPrepend,
+		pathAppend,
+		pathRemovePattern
+	};
+}
+
+export function applyProductRuntimeEnvironment(
+	env: IProcessEnvironment,
+	runtimeEnv: IResolvedProductRuntimeEnvironment | undefined
+): void {
+	if (!runtimeEnv) {
+		return;
+	}
+
