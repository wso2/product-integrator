+	private getEmbeddedWelcomeThemeData(): IEmbeddedWelcomeThemeData {
+		const themeData = this.webviewThemeDataProvider.getWebviewThemeData();
+		const styles = Object.keys(themeData.styles).reduce<Record<string, string>>((result, key) => {
+			result[key] = String(themeData.styles[key]);
+			return result;
+		}, {});
+		return {
