+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Emitter } from '../../../../base/common/event.js';
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { ISecretStorageService } from '../../../../platform/secrets/common/secrets.js';
+import { AuthenticationSession, AuthenticationSessionAccount, AuthenticationSessionsChangeEvent, IAuthenticationProvider, IAuthenticationProviderSessionOptions } from '../../../services/authentication/common/authentication.js';
+import { WI_LOGIN_PROVIDER_ID } from './wso2Constants.js';
+
+interface WSO2Session {
+	id: string;
+	accessToken: string;
+	account: AuthenticationSessionAccount;
+	scopes: ReadonlyArray<string>;
+	timestamp: number;
+}
+
+export class WSO2AuthenticationProvider extends Disposable implements IAuthenticationProvider {
+	readonly id = WI_LOGIN_PROVIDER_ID;
+	readonly label = 'WSO2 Integrator';
+	readonly supportsMultipleAccounts = false;
+
+	private readonly _onDidChangeSessions = this._register(new Emitter<AuthenticationSessionsChangeEvent>());
+	readonly onDidChangeSessions = this._onDidChangeSessions.event;
+
+	private readonly SESSION_KEY = 'wso2.integrator.session';
+
+	constructor(
+		@ISecretStorageService private readonly secretStorage: ISecretStorageService
+	) {
+		super();
+	}
+
+	async getSessions(scopes: string[] | undefined, options: IAuthenticationProviderSessionOptions): Promise<readonly AuthenticationSession[]> {
+		try {
+			const sessionData = await this.secretStorage.get(this.SESSION_KEY);
+			if (sessionData) {
+				const session: WSO2Session = JSON.parse(sessionData);
+				return [session];
+			}
+		} catch (error) {
+			console.error('Failed to get WSO2 sessions:', error);
+		}
+		return [];
+	}
+
+	async createSession(scopes: string[], options: IAuthenticationProviderSessionOptions): Promise<AuthenticationSession> {
+		// Mock authentication - in production, this would call a real auth endpoint
+		const sessionId = 'wso2-session-' + Date.now();
+		const email = (options as IAuthenticationProviderSessionOptions & { email?: string }).email || 'user@wso2.com';
+
+		const session: WSO2Session = {
+			id: sessionId,
+			accessToken: 'mock-token-' + Math.random().toString(36).substring(2),
+			account: {
+				id: email,
+				label: email
+			},
+			scopes: scopes || [],
+			timestamp: Date.now()
+		};
+
+		try {
+			await this.secretStorage.set(this.SESSION_KEY, JSON.stringify(session));
+			this._onDidChangeSessions.fire({ added: [session], removed: [], changed: [] });
+			return session;
+		} catch (error) {
+			console.error('Failed to create WSO2 session:', error);
+			throw error;
+		}
+	}
+
+	async removeSession(sessionId: string): Promise<void> {
+		try {
+			const sessions = await this.getSessions(undefined, {});
+			const session = sessions.find(s => s.id === sessionId);
+
+			await this.secretStorage.delete(this.SESSION_KEY);
+
+			if (session) {
+				this._onDidChangeSessions.fire({ added: [], removed: [session], changed: [] });
+			}
+		} catch (error) {
+			console.error('Failed to remove WSO2 session:', error);
+			throw error;
+		}
+	}
+
+	async removeAllSessions(): Promise<void> {
+		try {
+			const sessions = await this.getSessions(undefined, {});
+			await this.secretStorage.delete(this.SESSION_KEY);
+
+			if (sessions.length > 0) {
+				this._onDidChangeSessions.fire({ added: [], removed: [...sessions], changed: [] });
+			}
+		} catch (error) {
+			console.error('Failed to remove all WSO2 sessions:', error);
+			throw error;
+		}
+	}
+}
