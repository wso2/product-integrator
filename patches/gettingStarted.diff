+				align-items: center;
+				color: white;
+			}
+
+			.wso2-login-dialog .logo-container {
+				margin-bottom: 60px;
+			}
+
+			.wso2-login-dialog .logo {
+				max-width: 200px;
+				height: auto;
+				display: block;
+			}
+
+			.wso2-login-dialog .login-headline {
+				font-size: 42px;
+				font-weight: 700;
+				margin: 0 0 24px 0;
+				line-height: 1.2;
+			}
+
+			.wso2-login-dialog .login-caption {
+				font-size: 18px;
+				line-height: 1.6;
+				margin: 0;
+				color: rgba(255, 255, 255, 0.9);
+				max-width: 500px;
+			}
+
+			.wso2-login-dialog .login-right-section {
+				background: var(--vscode-sideBar-background);
+				padding: 0;
+				display: flex;
