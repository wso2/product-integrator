+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { IAuthenticationService } from '../../../services/authentication/common/authentication.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+import { WSO2_PLATFORM_CANCEL_SIGN_IN_COMMAND, WSO2_PLATFORM_PROVIDER_ID } from './wso2Constants.js';
+
+export interface WSO2LoginStatus {
+	isLoggedIn: boolean;
+	email?: string;
+	userEmail?: string;
+}
+
+/**
+ * Check the login status using the WSO2 Platform authentication provider
+ *
+ * @param authenticationService - The authentication service to check for sessions
+ * @returns Promise<WSO2LoginStatus> - The login status with user email if logged in
+ */
+export async function checkWSO2LoginStatus(
+	authenticationService: IAuthenticationService
+): Promise<WSO2LoginStatus> {
+	// Skip check if authService is not available (e.g., in tests)
+	if (!authenticationService) {
+		return { isLoggedIn: false };
+	}
+
+	try {
+		// Get all sessions from the WSO2 Platform authentication provider
+		const sessions = await authenticationService.getSessions(WSO2_PLATFORM_PROVIDER_ID);
+
+		if (sessions.length > 0) {
+			// User is logged in, use the first session
+			const session = sessions[0];
+			return {
+				isLoggedIn: true,
+				email: session.account.label // The account label is typically the email
+			};
+		}
+
+		return { isLoggedIn: false };
+	} catch (error) {
+		console.error('Failed to check WSO2 login status:', error);
+		return { isLoggedIn: false };
+	}
+}
+
+/**
+ * Sign in using the WSO2 Platform authentication provider
+ *
+ * @param authenticationService - The authentication service to create a session
+ * @param commandService - The command service to execute cancellation command
+ * @param scopes - Optional scopes to request (defaults to [])
+ * @returns Promise<void>
+ */
+export async function signInWSO2(
+	authenticationService: IAuthenticationService,
+	commandService: ICommandService,
+	scopes: string[] = []
+): Promise<void> {
+	try {
+		// Cancel any ongoing sign-in first
+		await commandService.executeCommand(WSO2_PLATFORM_CANCEL_SIGN_IN_COMMAND);
+
+		// Create a new session with the WSO2 Platform provider
+		await authenticationService.createSession(
+			WSO2_PLATFORM_PROVIDER_ID,
+			scopes,
+			{
+				createIfNone: true,
+				forceNewSession: true,
+				platform: 'Devant'
+			}
+		);
+	} catch (error) {
+		console.error('WSO2 sign-in failed:', error);
+		throw error;
+	}
+}
