+		WSO2EditorGroupWatermark.autoLoginDialogHandled = true;
+		const loginDialog = this.instantiationService.createInstance(WSO2LoginDialog, dialogParent);
+		const loginDialogPromise = loginDialog.show().catch(error => {
+			console.error('Failed to show WSO2 login dialog:', error);
+			WSO2EditorGroupWatermark.autoLoginDialogHandled = false;
+			return false;
+		}).finally(() => {
+			loginDialog.dispose();
