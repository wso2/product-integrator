+
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { IStorageService, StorageScope } from '../../../../platform/storage/common/storage.js';
+import { IAuthenticationService } from '../../../services/authentication/common/authentication.js';
+import { IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';
+import { CommandsRegistry } from '../../../../platform/commands/common/commands.js';
+import { WSO2AuthenticationProvider } from './wso2AuthenticationProvider.js';
+import { WI_LOGIN_PROVIDER_ID, WI_SHOW_LOGIN_COMMAND_ID, WSO2_PLATFORM_LOGOUT_COMMAND_ID, WI_LOGIN_COMPLETED_KEY, WI_LOGIN_SKIPPED_KEY } from './wso2Constants.js';
+import { WSO2LoginDialog } from './wso2LoginDialog.js';
+import { mainWindow } from '../../../../base/browser/window.js';
+
+/**
+ * Registers WSO2 authentication provider and related commands
+ */
+export class WSO2AuthenticationContribution extends Disposable {
+
+	constructor(
+		@IAuthenticationService private readonly authService: IAuthenticationService,
+		@IInstantiationService private readonly instantiationService: IInstantiationService
+	) {
+		super();
+		this.registerAuthenticationProvider();
+		this.registerCommands();
+	}
+
+	private registerAuthenticationProvider(): void {
+		// Skip registration if authService is not available (e.g., in tests)
+		if (!this.authService) {
+			return;
+		}
+
+		// Register WSO2 authentication provider
+		const provider = this._register(this.instantiationService.createInstance(WSO2AuthenticationProvider));
+		this.authService.registerAuthenticationProvider(WI_LOGIN_PROVIDER_ID, provider);
+
+		// Cleanup on dispose
+		this._register({
+			dispose: () => {
+				this.authService.unregisterAuthenticationProvider(WI_LOGIN_PROVIDER_ID);
+			}
+		});
+	}
+
+	private registerCommands(): void {
+		// Register show login command
+		this._register(CommandsRegistry.registerCommand(WI_SHOW_LOGIN_COMMAND_ID, async (accessor) => {
+			const instantiationService = accessor.get(IInstantiationService);
+			const storageService = accessor.get(IStorageService);
+
+			// Clear skip flag if it exists
+			storageService.remove(WI_LOGIN_SKIPPED_KEY, StorageScope.APPLICATION);
+
+			// Create and show login dialog
+			// We need to append to the workbench container
+			// eslint-disable-next-line no-restricted-syntax
+			const workbenchElement = mainWindow.document.querySelector('.monaco-workbench');
+			if (workbenchElement) {
+				const loginDialog = instantiationService.createInstance(WSO2LoginDialog, workbenchElement as HTMLElement);
+				await loginDialog.show();
+				loginDialog.dispose();
+
+				// Reload window to refresh UI
+				mainWindow.document.location.reload();
+			}
+		}));
+
+		// Register logout command
+		this._register(CommandsRegistry.registerCommand(WSO2_PLATFORM_LOGOUT_COMMAND_ID, async (accessor) => {
+			const authService = accessor.get(IAuthenticationService);
+			const storageService = accessor.get(IStorageService);
+
+			try {
+				// Get current sessions
+				const sessions = await authService.getSessions(WI_LOGIN_PROVIDER_ID);
+
+				// Remove all sessions
+				for (const session of sessions) {
+					await authService.removeSession(WI_LOGIN_PROVIDER_ID, session.id);
+				}
+
+				// Clear storage flags
+				storageService.remove(WI_LOGIN_COMPLETED_KEY, StorageScope.APPLICATION);
+				storageService.remove(WI_LOGIN_SKIPPED_KEY, StorageScope.APPLICATION);
+
+				// Reload window to show login dialog again
+				mainWindow.document.location.reload();
+			} catch (error) {
+				console.error('Logout failed:', error);
+			}
+		}));
+	}
+}
