+	private installEmbeddedWelcomeLoaderBridge(shell: HTMLElement, host: HTMLElement, requestId: number): () => void {
+		const targetWindow = getWindow(shell);
+		let revealTimer: number | undefined;
+		let disposed = false;
+
+		const cleanupTimers = () => {
+			if (typeof revealTimer === 'number') {
+				targetWindow.clearTimeout(revealTimer);
+				revealTimer = undefined;
+			}
+			targetWindow.clearTimeout(fallbackTimer);
+		};
+
+		const reveal = () => {
+			if (disposed || typeof revealTimer === 'number') {
+				return;
+			}
+
+			revealTimer = targetWindow.setTimeout(() => {
+				if (!disposed && this.isCurrentRenderRequest(requestId) && shell.isConnected) {
+					shell.classList.add('embedded-welcome-shell-ready');
+				}
+				dispose();
+			}, 500);
+		};
+
+		const checkReady = () => {
+			if (this.hasReadyWebviewFrame(host)) {
+				reveal();
+			}
+		};
+
+		const observer = new targetWindow.MutationObserver(() => checkReady());
+		observer.observe(host, { childList: true, subtree: true, attributes: true, attributeFilter: ['class'] });
+
+		const fallbackTimer = targetWindow.setTimeout(() => {
+			if (!disposed && this.isCurrentRenderRequest(requestId) && shell.isConnected) {
+				shell.classList.add('embedded-welcome-shell-ready');
+			}
+			dispose();
+		}, 6000);
+
+		const dispose = () => {
+			if (disposed) {
+				return;
+			}
+
+			disposed = true;
+			observer.disconnect();
+			cleanupTimers();
+		};
+
+		checkReady();
+		return dispose;
+	}
+
+	private hasReadyWebviewFrame(host: HTMLElement): boolean {
+		for (let element: Element | null = host.firstElementChild; element; element = element.nextElementSibling) {
+			if (this.isReadyWebviewFrame(element) || this.hasReadyWebviewFrameInSubtree(element)) {
+				return true;
+			}
+		}
+
+		return false;
+	}
+
+	private hasReadyWebviewFrameInSubtree(root: Element): boolean {
+		for (let element: Element | null = root.firstElementChild; element; element = element.nextElementSibling) {
+			if (this.isReadyWebviewFrame(element) || this.hasReadyWebviewFrameInSubtree(element)) {
+				return true;
+			}
+		}
+
+		return false;
+	}
+
+	private isReadyWebviewFrame(element: Element): boolean {
+		return element.tagName === 'IFRAME' && element.classList.contains('webview') && element.classList.contains('ready');
+	}
