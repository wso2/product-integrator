+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { $, append, clearNode, getWindow } from '../../../../base/browser/dom.js';
+import { Disposable, MutableDisposable } from '../../../../base/common/lifecycle.js';
+import { joinPath } from '../../../../base/common/resources.js';
+import { IWorkspaceContextService, WorkbenchState } from '../../../../platform/workspace/common/workspace.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+import { IConfigurationService } from '../../../../platform/configuration/common/configuration.js';
+import { IEditorGroupsService, GroupsOrder } from '../../../services/editor/common/editorGroupsService.js';
+import { IWebviewElement, IWebviewService } from '../../../contrib/webview/browser/webview.js';
+import { asWebviewUri } from '../../../contrib/webview/common/webview.js';
+import { IExtensionService } from '../../../services/extensions/common/extensions.js';
+import { WI_EMBEDDED_WELCOME_BOOTSTRAP_COMMAND_ID, WI_EMBEDDED_WELCOME_VIEW_TYPE, WI_EXTENSION_ID } from './wso2Constants.js';
+
+interface IEmbeddedWelcomeBootstrap {
+	mode: 'proxy' | 'websocket';
+	wsServer: string;
+	wsPort: number;
+}
+
+export class WSO2EditorGroupWatermark extends Disposable {
+
+	private readonly container: HTMLElement;
+	private readonly embeddedWebview = this._register(new MutableDisposable<IWebviewElement>());
+	private enabled = false;
+	private workbenchState: WorkbenchState;
+	private renderRequestId = 0;
+
+	constructor(
+		parent: HTMLElement,
+		@IWorkspaceContextService private readonly contextService: IWorkspaceContextService,
+		@ICommandService private readonly commandService: ICommandService,
+		@IConfigurationService private readonly configurationService: IConfigurationService,
+		@IEditorGroupsService private readonly editorGroupsService: IEditorGroupsService,
+		@IExtensionService private readonly extensionService: IExtensionService,
+		@IWebviewService private readonly webviewService: IWebviewService
+	) {
+		super();
+
+		this.workbenchState = this.contextService.getWorkbenchState();
+
+		this.container = append(parent, $('.wso2-editor-watermark'));
+		this.addStyles();
+		this.registerListeners();
+
+		if (this.workbenchState === WorkbenchState.EMPTY) {
+			void this.closeAllEditors();
+		}
+
+		void this.render();
+	}
+
+	private registerListeners(): void {
+		this._register(this.contextService.onDidChangeWorkbenchState(workbenchState => {
+			if (this.workbenchState !== workbenchState) {
+				this.workbenchState = workbenchState;
+				if (workbenchState === WorkbenchState.EMPTY) {
+					void this.closeAllEditors();
+				}
+				void this.render();
+			}
+		}));
+
+		this._register(this.extensionService.onDidRegisterExtensions(() => {
+			if (this.workbenchState !== WorkbenchState.EMPTY || this.embeddedWebview.value) {
+				return;
+			}
+
+			void this.render();
+		}));
+	}
+
+	private addStyles(): void {
+		const style = getWindow(this.container).document.createElement('style');
+		style.textContent = `
+			.monaco-workbench .part.editor > .content .editor-group-container:not(.empty) > .wso2-editor-watermark {
+				display: none;
+			}
+
+			.wso2-editor-watermark {
+				position: absolute;
+				inset: 0;
+				pointer-events: all;
+				overflow: hidden;
+				background: var(--vscode-editor-background);
+			}
+
+			.wso2-editor-watermark .embedded-welcome-host {
+				position: absolute;
+				inset: 0;
+				overflow: hidden;
+			}
+		`;
+		getWindow(this.container).document.head.appendChild(style);
+		this._register({ dispose: () => style.remove() });
+	}
+
+	private async render(): Promise<void> {
+		this.enabled = this.configurationService.getValue<boolean>('workbench.tips.enabled') !== false;
+		const shouldShow = this.workbenchState === WorkbenchState.EMPTY && this.enabled;
+
+		if (!shouldShow) {
+			this.renderRequestId++;
+			this.disposeEmbeddedWelcome();
+			clearNode(this.container);
+			return;
+		}
+
+		if (this.embeddedWebview.value) {
+			return;
+		}
+
+		const requestId = ++this.renderRequestId;
+		clearNode(this.container);
+		const host = append(this.container, $('.embedded-welcome-host'));
+
+		try {
+			await this.renderEmbeddedWelcome(host, requestId);
+		} catch (error) {
+			if (requestId !== this.renderRequestId) {
+				return;
+			}
+
+			console.error('Failed to render embedded welcome view:', error);
+			this.disposeEmbeddedWelcome();
+			clearNode(this.container);
+		}
+	}
+
+	private async renderEmbeddedWelcome(host: HTMLElement, requestId: number): Promise<void> {
+		await this.extensionService.activateByEvent(`onCommand:${WI_EMBEDDED_WELCOME_BOOTSTRAP_COMMAND_ID}`);
+		const bootstrap = await this.commandService.executeCommand(WI_EMBEDDED_WELCOME_BOOTSTRAP_COMMAND_ID) as IEmbeddedWelcomeBootstrap | undefined;
+
+		if (!this.isCurrentRenderRequest(requestId)) {
+			return;
+		}
+
+		if (!bootstrap) {
+			throw new Error('Missing embedded welcome bootstrap response');
+		}
+
+		const extension = await this.extensionService.getExtension(WI_EXTENSION_ID);
+
+		if (!this.isCurrentRenderRequest(requestId)) {
+			return;
+		}
+
+		if (!extension) {
+			throw new Error(`Unable to locate extension ${WI_EXTENSION_ID}`);
+		}
+
+		const resourcesRoot = joinPath(extension.extensionLocation, 'resources');
+		const scriptUri = asWebviewUri(joinPath(resourcesRoot, 'jslibs', 'main.js')).toString(true);
+		const webview = this.webviewService.createWebviewElement({
+			providedViewType: WI_EMBEDDED_WELCOME_VIEW_TYPE,
+			title: 'WSO2 Integrator',
+			options: {},
+			contentOptions: {
+				allowScripts: true,
+				localResourceRoots: [resourcesRoot]
+			},
+			extension: {
+				id: extension.identifier,
+				location: extension.extensionLocation
+			}
+		});
+
+		if (!this.isCurrentRenderRequest(requestId)) {
+			webview.dispose();
+			return;
+		}
+
+		this.embeddedWebview.value = webview;
+		webview.mountTo(host, getWindow(host));
+		webview.setHtml(this.getEmbeddedWelcomeHtml(scriptUri, bootstrap));
+	}
+
+	private getEmbeddedWelcomeHtml(scriptUri: string, bootstrap: IEmbeddedWelcomeBootstrap): string {
+		const serializedBootstrap = JSON.stringify(bootstrap).replace(/</g, '\\u003c');
+
+		return `<!DOCTYPE html>
+			<html lang="en">
+			<head>
+				<meta charset="utf-8">
+				<meta name="viewport" content="width=device-width,initial-scale=1,shrink-to-fit=no">
+				<title>WSO2 Integrator</title>
+				<style>
+					html, body, #root {
+						width: 100%;
+						height: 100%;
+						margin: 0;
+						padding: 0;
+						overflow: hidden;
+						background: var(--vscode-editor-background);
+					}
+				</style>
+			</head>
+			<body>
+				<div id="root"></div>
+				<script>
+					window.__WI_BRIDGE_BOOTSTRAP = ${serializedBootstrap};
+				</script>
+				<script src="${scriptUri}"></script>
+				<script>
+					wiWebview.renderWebview(document.getElementById('root'));
+				</script>
+			</body>
+			</html>`;
+	}
+
+	private isCurrentRenderRequest(requestId: number): boolean {
+		return requestId === this.renderRequestId;
+	}
+
+	private disposeEmbeddedWelcome(): void {
+		this.embeddedWebview.clear();
+	}
+
+	private async closeAllEditors(): Promise<void> {
+		try {
+			await Promise.all(
+				this.editorGroupsService.getGroups(GroupsOrder.MOST_RECENTLY_ACTIVE).map(group =>
+					group.closeAllEditors({ excludeSticky: false })
+				)
+			);
+		} catch (error) {
+			console.error('Failed to close editors:', error);
+		}
+	}
+}
