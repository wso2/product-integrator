+ *--------------------------------------------------------------------------------------------*/
+
+import { $, append } from '../../../../base/browser/dom.js';
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { IStorageService, StorageScope, StorageTarget } from '../../../../platform/storage/common/storage.js';
+import { WI_LOGIN_COMPLETED_KEY, WI_LOGIN_SKIPPED_KEY, WSO2_PLATFORM_CANCEL_SIGN_IN_COMMAND } from './wso2Constants.js';
+import { FileAccess } from '../../../../base/common/network.js';
+import { mainWindow } from '../../../../base/browser/window.js';
+import { checkWSO2LoginStatus, signInWSO2 } from './wso2AuthUtils.js';
+import { IAuthenticationService } from '../../../services/authentication/common/authentication.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+
+export class WSO2LoginDialog extends Disposable {
+
+	private container: HTMLElement | null = null;
+	private resolvePromise: ((value: boolean) => void) | null = null;
+
+	constructor(
+		private readonly parent: HTMLElement,
+		@IStorageService private readonly storageService: IStorageService,
+		@IAuthenticationService private readonly authenticationService: IAuthenticationService,
+		@ICommandService private readonly commandService: ICommandService,
+	) {
+		super();
+	}
+
+	async show(): Promise<boolean> {
+		const loginCompleted = this.storageService.getBoolean(WI_LOGIN_COMPLETED_KEY, StorageScope.APPLICATION, false);
+		if (loginCompleted) {
+			const loginStatus = await checkWSO2LoginStatus(this.authenticationService);
+			if (loginStatus.isLoggedIn) {
+				return false;
+			}
+
+			// The stored completion flag is stale if there is no active session.
+			this.storageService.remove(WI_LOGIN_COMPLETED_KEY, StorageScope.APPLICATION);
+		}
+
+		// Show login UI
+		this.createLoginUI();
+
+		// Return promise that resolves when login completes or is skipped
+		return new Promise<boolean>((resolve) => {
+			this.resolvePromise = resolve;
+		});
+	}
+
+	private createLoginUI(): void {
+		// Create overlay container
+		this.container = append(this.parent, $('.wso2-login-dialog'));
+
+		// Add styles
+		this.addStyles();
+
+		const wrapper = append(this.container, $('.login-wrapper'));
+
+		// Left section with branding
+		const leftSection = append(wrapper, $('.login-left-section'));
+
+		const logoContainer = append(leftSection, $('.logo-container'));
+		const logo = append(logoContainer, $('img.logo')) as HTMLImageElement;
+		logo.src = FileAccess.asBrowserUri('vs/workbench/browser/parts/editor/media/integrator-activity-icon-dark.svg').toString(true);
+		logo.alt = 'WSO2 Integrator';
+
+		const heroBadge = append(leftSection, $('div.login-badge'));
+		heroBadge.textContent = 'Get Started';
+
+		const headline = append(leftSection, $('h1.login-headline'));
+		headline.textContent = 'Welcome to WSO2 Integrator';
+
+		const caption = append(leftSection, $('p.login-caption'));
+		caption.textContent = 'Connect AI agents, APIs, data, and events across cloud, on-prem, and hybrid environments. Build any type of integration and AI agent with the 100% open source WSO2 Integrator.';
+
+		// Right section with login form
+		const rightSection = append(wrapper, $('.login-right-section'));
+
+		const formContainer = append(rightSection, $('.login-form-container'));
+
+		const formOverline = append(formContainer, $('div.form-overline'));
+		formOverline.textContent = 'WSO2 Integrator';
+
+		const formTitle = append(formContainer, $('h2.form-title'));
+		formTitle.textContent = 'Get Started';
+
+		const formSubtitle = append(formContainer, $('p.form-subtitle'));
+		formSubtitle.textContent = 'Sign in to access AI features and for seamless deployment to WSO2 Cloud';
+
+		// Loader container (shown initially while checking login status)
+		const loaderContainer = append(formContainer, $('.loader-container'));
+		append(loaderContainer, $('.spinner'));
+		const loaderText = append(loaderContainer, $('.loader-text'));
+		loaderText.textContent = 'Checking login status...';
+
+		// Error message container
+		const errorContainer = append(formContainer, $('.error-message'));
+		errorContainer.style.display = 'none';
+
+		// Sign In with WSO2 button (hidden initially)
+		const signInButton = append(formContainer, $('button.wso2-sign-in-btn')) as HTMLButtonElement;
+		signInButton.style.display = 'none';
+		const textSpan = append(signInButton, $('span.btn-text'));
+		textSpan.textContent = 'Sign in with WSO2 account';
+
+		// Skip button (hidden initially)
+		const skipButton = append(formContainer, $('button.skip-btn')) as HTMLButtonElement;
+		skipButton.textContent = 'Skip for now';
+		skipButton.style.display = 'none';
+
+		// Add event listeners
+		signInButton.addEventListener('click', () => this.handleSignIn(errorContainer, signInButton, loaderContainer, loaderText, skipButton));
+		skipButton.addEventListener('click', () => this.handleSkip());
+
+		// Check login status in background
+		this.checkInitialLoginStatus(loaderContainer, signInButton, skipButton, loaderText);
+	}
+
+	private async handleSignIn(errorContainer: HTMLElement, button: HTMLButtonElement, loaderContainer: HTMLElement, loaderText: HTMLElement, skipButton: HTMLButtonElement): Promise<void> {
+		// Clear previous error
+		errorContainer.style.display = 'none';
+		errorContainer.textContent = '';
+
+		// Show loader immediately
+		loaderText.textContent = 'Opening sign-in page...';
+		loaderContainer.style.display = 'flex';
+		button.style.display = 'none';
+		skipButton.style.display = 'none';
+
+		// Add cancel button to loader
+		const cancelButton = append(loaderContainer, $('button.cancel-btn')) as HTMLButtonElement;
+		cancelButton.textContent = 'Cancel';
+		cancelButton.style.marginTop = '16px';
+
+		let cancelled = false;
+
+		// Cancel handler
+		const cancelHandler = () => {
+			cancelled = true;
+			loaderContainer.style.display = 'none';
+			button.style.display = 'flex';
+			skipButton.style.display = 'block';
+			cancelButton.remove();
+			this.commandService.executeCommand(WSO2_PLATFORM_CANCEL_SIGN_IN_COMMAND);
+		};
+
+		cancelButton.addEventListener('click', cancelHandler);
+
+		// Update message after sign-in page opens
+		setTimeout(() => {
+			if (!cancelled) {
+				loaderText.textContent = 'Waiting for authentication...';
+			}
+		}, 1000);
+
+		// Trigger sign-in immediately without waiting
+		signInWSO2(this.authenticationService, this.commandService).then(async () => {
+			if (cancelled) {
+				return;
+			}
+
+			// Verify login was successful
+			const loginStatus = await checkWSO2LoginStatus(this.authenticationService);
+
+			if (loginStatus.isLoggedIn) {
+				// Store login state
+				this.storageService.store(WI_LOGIN_COMPLETED_KEY, true, StorageScope.APPLICATION, StorageTarget.MACHINE);
+				this.storageService.remove(WI_LOGIN_SKIPPED_KEY, StorageScope.APPLICATION);
+
+				// Close dialog and resolve
+				this.close(true);
+			} else {
+				throw new Error('Login verification failed');
+			}
+		}).catch((error: Error) => {
+			if (cancelled) {
+				return;
+			}
+			console.error('Login failed:', error);
+			errorContainer.textContent = 'Authentication failed. Please try again.';
+			errorContainer.style.display = 'block';
+			loaderContainer.style.display = 'none';
+			button.style.display = 'flex';
+			skipButton.style.display = 'block';
+			cancelButton.remove();
+		});
+	}
+
+	private async checkInitialLoginStatus(loaderContainer: HTMLElement, signInButton: HTMLButtonElement, skipButton: HTMLButtonElement, loaderText: HTMLElement): Promise<void> {
+		try {
+			const loginStatus = await checkWSO2LoginStatus(this.authenticationService);
+			if (loginStatus.isLoggedIn) {
+				// User is already logged in, close dialog
+				this.storageService.store(WI_LOGIN_COMPLETED_KEY, true, StorageScope.APPLICATION, StorageTarget.MACHINE);
+				this.close(true);
+				return;
+			}
+		} catch (error) {
+			console.error('Failed to check login status:', error);
+		}
+
+		// Not logged in, show sign-in button
+		loaderContainer.style.display = 'none';
+		signInButton.style.display = 'flex';
+		skipButton.style.display = 'block';
+	}
+
+	private handleSkip(): void {
+		// Store skip state
+		this.storageService.store(WI_LOGIN_SKIPPED_KEY, true, StorageScope.APPLICATION, StorageTarget.MACHINE);
+		this.storageService.remove(WI_LOGIN_COMPLETED_KEY, StorageScope.APPLICATION);
+
+		// Close dialog and resolve
+		this.close(false);
+	}
+
+	private close(loggedIn: boolean): void {
+		if (this.container) {
+			this.container.remove();
+			this.container = null;
+		}
+
+		if (this.resolvePromise) {
+			this.resolvePromise(loggedIn);
+			this.resolvePromise = null;
+		}
+	}
+
+	private addStyles(): void {
+		const style = document.createElement('style');
+		style.textContent = `
+			.wso2-login-dialog {
+				--wso2-brand-primary: #17223a;
+				--wso2-brand-primary-alt: #1b2a49;
+				--wso2-brand-ink: #17223a;
+				--wso2-brand-ink-alt: #1b2a49;
